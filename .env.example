# Telegram token from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: lock bot to one Telegram chat_id. If empty, first user who writes /start becomes owner.
ADMIN_CHAT_ID=

# Poll interval in seconds (can be changed later via /interval command, min 30)
POLL_INTERVAL_SECONDS=120

# Soft mode reduces request rate to lower 429 risk on Avito.
SOFT_MODE=true
SOFT_JITTER_SECONDS=180

# Max notifications per check cycle
MAX_NOTIFICATIONS_PER_CYCLE=10

# SQLite state DB
STATE_DB_PATH=state.sqlite3

# Avito region path, e.g. rossiya, moskva, sankt-peterburg
AVITO_REGION=rossiya
